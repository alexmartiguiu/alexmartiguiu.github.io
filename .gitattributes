# Auto detect text files and normalize line endings to LF
* text=auto

# JavaScript files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# JSON
*.json text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
